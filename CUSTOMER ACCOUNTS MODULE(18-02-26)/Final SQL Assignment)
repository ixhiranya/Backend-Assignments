SELECT c.cust_id,c.cust_name,COUNT(DISTINCT s.s_id) as Total_Shipments,SUM(i.amount) AS Total_Invoice_Amount FROM CUSTOMERS c
LEFT JOIN SHIPMENTS s ON c.cust_id=s.cust_id 
LEFT JOIN INVOICES i ON c.cust_id=i.cust_id GROUP BY c.cust_id,c.cust_name;

SELECT c.cust_id,c.cust_name,b.b_name,co.comp_name FROM CUSTOMERS C
LEFT JOIN BRANCHES b ON c.b_id=b.b_id
LEFT JOIN COMPANY co ON b.company_id=co.company_id
GROUP BY c.cust_id,c.cust_name,b.b_name,co.comp_name;

SELECT c.cust_name, d.d_id,d.doc_type,d.exp_date AS expired_date FROM CUSTOMERS c
LEFT JOIN DOCUMENTS d ON c.cust_id=d.cust_id WHERE d.exp_date<GETDATE();

SELECT c.cust_id,c.cust_name AS InActive_customers,c.status,i.invoice_status AS invoice_payment_status FROM CUSTOMERS c 
LEFT JOIN INVOICES i ON c.cust_id=i.cust_id WHERE c.status LIKE 'INACTIVE' AND i.invoice_status LIKE 'UNPAID' ;

SELECT c.cust_name,s.ship_status AS active_shipments, COUNT(cl.claim_status) AS open_claims FROM CUSTOMERS c
LEFT JOIN SHIPMENTS s ON c.cust_id=s.cust_id
LEFT JOIN CLAIMS cl ON c.cust_id=cl.cust_id WHERE s.ship_status LIKE 'ACTIVE' AND cl.claim_status LIKE 'OPEN' GROUP BY c.cust_id,c.cust_name,s.ship_status,cl.claim_status ;