create database Customer_Accounts_Module;

CREATE TABLE CUSTOMERS(cust_id INT IDENTITY(1,1) PRIMARY KEY,
					   cust_name VARCHAR(15) NOT NULL,
					   status VARCHAR(20) CHECK (status IN ('ACTIVE','INACTIVE')) DEFAULT 'ACTIVE',
					   created_at DATETIME DEFAULT CURRENT_TIMESTAMP);

CREATE TABLE COMPANY(company_id INT IDENTITY(1,1) PRIMARY KEY,
					 comp_name VARCHAR(20) NOT NULL,
					 status VARCHAR(10) CHECK (status IN('ACTIVE','INACTIVE')) DEFAULT 'ACTIVE');

CREATE TABLE BRANCHES(b_id INT PRIMARY KEY,
					  b_name VARCHAR(20),
					  company_id INT FOREIGN KEY REFERENCES COMPANY(company_id));
DROP TABLE BRANCHES;

CREATE TABLE CATEGORY(cat_id INT PRIMARY KEY, cat_name VARCHAR(20) UNIQUE);

ALTER TABLE CUSTOMERS ADD company_id INT FOREIGN KEY REFERENCES COMPANY(company_id);

ALTER TABLE CUSTOMERS ADD b_id INT FOREIGN KEY REFERENCES BRANCHES(b_id);
ALTER TABLE CUSTOMERS DROP b_id;

ALTER TABLE CUSTOMERS ADD cat_id INT FOREIGN KEY REFERENCES CATEGORY(cat_id);

CREATE TABLE ADDRESS(a_id INT PRIMARY KEY NOT NULL,
                     cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
					 a_type VARCHAR(20) CHECK( a_type IN('BILLING','PICKING','DELIVERY')),
					 a_line VARCHAR(200),
					 city VARCHAR(10));

CREATE TABLE CERDIT_DETAILS(cd_id INT PRIMARY KEY,
                            cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
							limit DECIMAL(10,2),
							from_date DATE ,
							to_date  DATE);

CREATE TABLE DOCUMENTS(d_id INT PRIMARY KEY,
                       cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
					   doc_type VARCHAR(20),
					   exp_date DATE,
					   file_path VARCHAR(200));

CREATE TABLE SHIPMENTS(s_id INT PRIMARY KEY,
                       cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
					   ship_status VARCHAR(10) CHECK(ship_status IN ('ACTIVE','COMPLETED','CANCELLED')));

cREATE TABLE CLAIMS(claim_id INT PRIMARY KEY,
                    cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
					claim_status VARCHAR(10) CHECK(claim_status IN ('OPEN','CLOSE')));

CREATE TABLE INVOICES(invoice_id INT PRIMARY KEY,
                      cust_id INT FOREIGN KEY REFERENCES CUSTOMERS(cust_id),
					  amount BIGINT,
					  invoice_status VARCHAR(15) CHECK(invoice_status IN('PAID','UNPAID')));

